---
import FormattedDate from "./FormattedDate.astro";
import type { CollectionEntry } from 'astro:content';
import BookOpen from '@lucide/astro/icons/book-open';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Calendar from '@lucide/astro/icons/calendar';
import Tags from '@lucide/astro/icons/tags';

interface Props {
  title: string;
  seriesName: string;
  posts: CollectionEntry<'blog'>[];
  viewAllLink: string;
  epicColor: string;
}

const { title, seriesName, posts, viewAllLink, epicColor } = Astro.props;

// 計算顯示的文章數量 - 最多顯示5篇文章
const displayCount = Math.min(2, posts.length);
---

<div class="series-block" style={`--series-color: ${epicColor}`}>
  <div class="series-header">
    <h2 class="series-title">
      <BookOpen size={24} />
      {title}
    </h2>
    {posts.length > 0 && (
      <a href={viewAllLink} class="view-all">
        查看全部
        <ArrowRight size={16} />
      </a>
    )}
  </div>
  
  {posts.length > 0 ? (
    <div class="posts-list">
      {posts.slice(0, displayCount).map((post) => {
        const path = post.id.slice(0, post.id.lastIndexOf("/")).toLowerCase();
        return (
          <article class="post-card">
            <div class="post-content-wrapper">
              <div class="post-meta-row">
                <div class="post-date">
                  <Calendar size={16} />
                  <FormattedDate date={post.data.date} />
                </div>
                
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-tags">
                    <Tags size={16} />
                    <div class="tag-wrapper">
                      {post.data.tags?.map((tag: string) => (
                        <a href={`/tags/${tag.toLowerCase()}/`} class="tag-link">
                          {tag}
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
              
              <h3 class="post-title">
                <a href={`/post/${path}/`}>{post.data.title}</a>
              </h3>
              
              {post.data.description && (
                <div class="post-excerpt">
                  {post.data.description}
                </div>
              )}
              
              <div class="post-actions">
                <a href={`/post/${path}/`} class="read-more">
                  繼續閱讀
                  <ArrowRight size={14} />
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  ) : (
    <div class="no-posts">
      <p>暫無相關文章</p>
    </div>
  )}
</div>

<style>
  /* 使用統一的設計令牌 */

  .series-block {
    margin-bottom: 2rem;
  }

  .series-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--series-color, #4299e1);
  }

  .series-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .series-title svg {
    color: var(--series-color, #4299e1);
  }

  .view-all {
    font-size: 0.9rem;
    color: var(--series-color, #4299e1);
    text-decoration: none;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.2rem;
    font-weight: 500;
  }

  .view-all:hover {
    opacity: 0.8;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-card {
    background-color: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 8px;
    margin-bottom: 1rem;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .post-card:hover {
    box-shadow: 0 5px 15px var(--card-shadow);
  }

  .post-content-wrapper {
    padding: 1rem;
    display: flex;
    flex-direction: column;
  }

  .post-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--color-border-light);
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-date {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .tag-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-link {
    background-color: var(--color-bg-muted);
    color: var(--color-text-muted);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .tag-link:hover {
    background-color: var(--color-text-muted);
    color: white;
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
  }

  .post-title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-title a:hover {
    color: var(--series-color, #4299e1);
  }

  .post-excerpt {
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .post-actions {
    margin-top: auto;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.9rem;
    color: var(--series-color, #4299e1);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .read-more:hover {
    opacity: 0.8;
  }

  .no-posts {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    background-color: var(--color-bg-secondary);
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .post-meta-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
